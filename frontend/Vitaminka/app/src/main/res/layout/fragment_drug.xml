<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A000000">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:id="@+id/ll_images"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:clipChildren="false"
            android:layout_marginTop="10dp">

            <androidx.viewpager2.widget.ViewPager2
                android:id="@+id/viewpager_images"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:clipToPadding="false"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:clipChildren="false"/>

            <com.google.android.material.tabs.TabLayout
                android:id="@+id/tab_indicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:background="@drawable/rounded_corner_bg"
                android:backgroundTint="@color/acbg"
                app:tabGravity="center"
                app:tabMode="fixed"
                app:tabIndicatorHeight="0dp"
                app:tabPaddingStart="4dp"
                app:tabPaddingEnd="4dp"
                app:tabPaddingTop="4dp"
                app:tabPaddingBottom="4dp"
                android:layout_margin="8dp"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tv_info1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Цены в приложении могут отличаться от цен в аптеках"
            android:textColor="#8030303B"
            android:textStyle="bold"
            android:gravity="center_vertical"
            android:drawableStart="@drawable/info_icon"
            android:drawablePadding="10dp"/>

        <TextView
            android:id="@+id/tv_info2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Внешний вид товара может отличаться от изображения на фотографии"
            android:textColor="#8030303B"
            android:textStyle="bold"
            android:gravity="center_vertical"
            android:drawableStart="@drawable/info_icon"
            android:drawablePadding="10dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="invisible"
            android:layout_marginTop="10dp"
            android:padding="5dp"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:text="Акция"
            android:textStyle="bold"
            android:textSize="14sp"
            android:textColor="@color/white"
            android:background="@drawable/rounded_corner_bg"
            android:backgroundTint="@color/imp"/>

        <TextView
            android:id="@+id/textView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Название товара"
            android:textColor="@color/bg"
            android:textSize="20sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tv_btn_characteristics"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="30dp"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:text="Характеристики"
            android:textColor="@color/bg"
            android:textStyle="bold"
            android:textSize="16sp"
            android:clickable="true"
            android:drawableEnd="@drawable/arrow_down_light"
            android:background="@drawable/rounded_outline_bg"
            android:backgroundTint="#3330303B" />

        <TextView
            android:id="@+id/tv_btn_description"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:text="Описание"
            android:textColor="@color/bg"
            android:textStyle="bold"
            android:textSize="16sp"
            android:clickable="true"
            android:drawableEnd="@drawable/arrow_down_light"
            android:background="@drawable/rounded_outline_bg"
            android:backgroundTint="#3330303B"/>

    </LinearLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:background="#BBE1D4">

        <TextView
            android:id="@+id/tv_new_price"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="869.00₽"
            android:textColor="@color/bg"
            android:textSize="25sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tv_old_price"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="invisible"
            android:text="966.00₽"
            android:textColor="#8030303B"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginStart="15dp"
            android:layout_marginBottom="10dp"
            app:layout_constraintBottom_toTopOf="@+id/btn_add_to_cart"
            app:layout_constraintStart_toEndOf="@id/tv_new_price"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:gravity="center_vertical"
            android:text="В наличии"
            android:textColor="#009499"
            android:textSize="16sp"
            android:drawableStart="@drawable/point_icon"
            android:drawableTint="#009499"
            android:drawablePadding="10dp"
            app:layout_constraintBottom_toTopOf="@+id/btn_add_to_cart"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />


        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_add_to_cart"
            android:layout_width="250dp"
            android:layout_height="45dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/rounded_outline_bg"
            android:backgroundTint="#009499"
            android:drawableStart="@drawable/cart_icon"
            android:paddingStart="35dp"
            android:paddingEnd="35dp"
            android:text="Добавить в корзину"
            android:textColor="@color/white"
            android:textAllCaps="false"
            android:textSize="16sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tv_new_price"
            tools:ignore="TouchTargetSizeCheck" />

        <ImageButton
            android:id="@+id/btn_favorite"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:layout_marginStart="30dp"
            android:background="@android:color/transparent"
            android:scaleType="fitCenter"
            android:src="@drawable/heart_icon"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/btn_add_to_cart"
            tools:ignore="ContentDescription,SpeakableTextPresentCheck,TouchTargetSizeCheck" />


    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>